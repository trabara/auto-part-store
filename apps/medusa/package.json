{
  "name": "medusa",
  "version": "0.0.1",
  "private": true,
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "check-types": "tsc --noEmit",
    "dev": "medusa develop",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "medusa:db:migrate": "medusa db:migrate",
    "medusa:db:generate": "medusa db:generate",
    "medusa:db:rollback": "medusa db:rollback",
    "medusa:user:create": "medusa user -e admin@example.com -p supersecret",
    "medusa:init": "yarn medusa:db:migrate && yarn medusa:user:create && yarn seed",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@agilo/medusa-analytics-plugin": "workspace:*",
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@repo/rbac-plugin": "workspace:*",
    "@repo/vehicle-fitment-plugin": "workspace:*"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.5",
    "@swc/core": "1.12.2",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  }
}
