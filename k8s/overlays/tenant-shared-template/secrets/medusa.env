# SHARED TIER - Uses managed PostgreSQL, Redis, and S3
# Replace these with your actual managed service credentials

# Tenant name (used for Redis cache prefix and database name)
TENANT_NAME=TENANT_NAME

# Shared PostgreSQL - medusa superuser (for migrations and runtime)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://medusa:SHARED_DB_PASS@SHARED_PG_HOST:5432/smap_TENANT_NAME?sslmode=disable

# Shared PostgreSQL - shared_user password (created by medusa-init via setup-shared-db.js)
# The medusa-init job uses the medusa superuser to create this role and GRANT privileges
SHARED_DB_PASS=SHARED_DB_PASS

# Shared Redis (external Docker container)
# Format: redis://:password@host:port
REDIS_URL=redis://:SHARED_REDIS_PASS@SHARED_REDIS_HOST:6379

# JWT and Cookie secrets (tenant-specific, generate unique per tenant)
JWT_SECRET=TENANT_JWT_SECRET_CHANGE_ME
COOKIE_SECRET=TENANT_COOKIE_SECRET_CHANGE_ME

# Shared S3/Spaces credentials (all tenants use same bucket or tenant-specific prefix)
MINIO_ACCESS_KEY=SHARED_SPACES_ACCESS_KEY
MINIO_SECRET_KEY=SHARED_SPACES_SECRET_KEY
MINIO_BUCKET=smap-store-shared

# Tenant admin credentials (unique per tenant)
MEDUSA_ADMIN_EMAIL=admin@TENANT_DOMAIN
MEDUSA_ADMIN_PASSWORD=TENANT_ADMIN_PASSWORD_CHANGE_ME

# Required for Medusa (set to false for HTTP/Traefik)
COOKIE_SECURE=false

# K8s API host for init job (shared tier pods can't reach cluster IP)
KUBERNETES_API_HOST=KUBERNETES_API_HOST
KUBERNETES_API_PORT=KUBERNETES_API_PORT
