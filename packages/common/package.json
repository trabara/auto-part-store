  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.0.0"
  },
  "devDependencies": {
    "@medusajs/framework": "2.13.5",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
