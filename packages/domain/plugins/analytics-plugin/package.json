{
  "name": "@repo/analytics-plugin",
  "version": "1.2.1",
  "description": "A simple analytics plugin for Medusa",
  "author": "Ante Primorac <ante@agilo.com>",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "name": "@trabara/analytics-plugin"
  },
  "license": "MIT",
  "packageManager": "yarn@4.12.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agilo/medusa-analytics-plugin.git"
  },
  "homepage": "https://github.com/Agilo/medusa-analytics-plugin#readme",
  "bugs": {
    "url": "https://github.com/Agilo/medusa-analytics-plugin/issues"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-integration",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "plugin-dev-watch . ../../apps/backend",
    "dev:init": "plugin-dev-init .",
    "prepublishOnly": "medusa plugin:build",
    "lint": "eslint .",
    "test": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit --passWithNoTests",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/icons": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@medusajs/test-utils": "2.13.5",
    "@medusajs/ui": "4.0.25",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@swc/core": "1.12.2",
    "@swc/jest": "^0.2.38",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.6.2",
    "@types/node": "^20.12.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "pg-god": "^1.0.12",
    "prop-types": "^15.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.19",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": ">=2.11.0 <3.0.0",
    "@medusajs/framework": ">=2.11.0 <3.0.0",
    "@medusajs/icons": ">=2.11.0 <3.0.0",
    "@medusajs/medusa": ">=2.11.0 <3.0.0",
    "@medusajs/ui": ">=4.0.0 <5.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@repo/scripts": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "luxon": "^3.6.1",
    "react-aria-components": "^1.10.1",
    "react-day-picker": "^9.13.2",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4"
  }
}
