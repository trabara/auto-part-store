{
  "name": "@repo/media-plugin",
  "version": "0.0.1",
  "description": "A Medusa plugin for media management, providing features such as uploading, storing, and retrieving media files. This plugin integrates with various storage providers and offers a flexible API for handling media assets within a Medusa application.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "name": "@trabara/fitment-plugin"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./links/*": "./.medusa/server/src/links/*.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-fitment",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "plugin-dev-watch . ../../../../apps/backend",
    "dev:init": "plugin-dev-init .",
    "prepublishOnly": "medusa plugin:build",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@hookform/resolvers": "^5.2.2",
    "@repo/domain-modules": "workspace:*",
    "@repo/hooks": "workspace:*",
    "@trabara/common": "workspace:*",
    "@trabara/core": "workspace:*",
    "@uiw/codemirror-theme-vscode": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "date-fns": "^4.1.0",
    "handlebars": "^4.7.8",
    "lodash": "^4.17.23",
    "lucide-react": "^0.563.0",
    "playwright": "^1.58.2",
    "react-hook-form": "^7.71.1"
  },
  "devDependencies": {
    "@medusajs/admin-bundler": "2.14.1",
    "@medusajs/admin-sdk": "2.14.1",
    "@medusajs/cli": "2.14.1",
    "@medusajs/framework": "2.14.1",
    "@medusajs/icons": "2.14.1",
    "@medusajs/medusa": "2.14.1",
    "@medusajs/test-utils": "2.14.1",
    "@medusajs/ui": "4.0.25",
    "@repo/eslint-config": "workspace:*",
    "@repo/scripts": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@swc/core": "1.12.2",
    "@swc/jest": "^0.2.38",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar": "^4.0.3",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": ">=2.11.0 <3.0.0",
    "@medusajs/framework": ">=2.11.0 <3.0.0",
    "@medusajs/icons": ">=2.11.0 <3.0.0",
    "@medusajs/medusa": ">=2.11.0 <3.0.0",
    "@medusajs/ui": ">=4.0.0 <5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
