{
  "name": "@repo/rbac-plugin",
  "version": "0.0.1",
  "description": "A Medusa plugin for role-based access control (RBAC) that provides a user interface for managing roles and permissions.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "name": "@trabara/rbac-plugin"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/i18n/*": "./.medusa/server/src/modules/i18n/*",
    "./middlewares/*": "./.medusa/server/src/middlewares/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa-plugin-integration",
    "medusa-v2"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "plugin-dev-watch . ../../../../apps/backend",
    "dev:init": "plugin-dev-init .",
    "prepublishOnly": "medusa plugin:build",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent=false --forceExit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@repo/admin": "workspace:*",
    "@repo/domain-modules": "workspace:*",
    "@repo/hooks": "workspace:*",
    "@trabara/common": "workspace:*",
    "@trabara/core": "workspace:*",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.563.0",
    "react-hook-form": "^7.71.1"
  },
  "devDependencies": {
    "@medusajs/admin-bundler": "2.13.6",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.0.25",
    "@repo/eslint-config": "workspace:*",
    "@repo/scripts": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@swc/core": "1.12.2",
    "@swc/jest": "^0.2.38",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar": "^4.0.3",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.0.25"
  },
  "engines": {
    "node": ">=20"
  }
}
