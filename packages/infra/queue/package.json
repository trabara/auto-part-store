{
  "name": "@trabara/queue",
  "version": "0.1.0",
  "description": "Redis queue abstraction for the smap-store platform",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/node": "^20.12.11",
    "eslint": "^9.39.1",
    "ioredis": "^5.6.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
