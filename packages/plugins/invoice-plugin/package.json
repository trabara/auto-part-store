{
  "name": "@repo/invoice-plugin",
  "version": "0.0.1",
  "description": "A Medusa plugin to generate invoices for orders",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/i18n/*": "./.medusa/server/src/modules/i18n/*",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-invoice",
    "medusa-plugin",
    "medusa-v2"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "plugin-dev-watch . ../../apps/medusa",
    "dev:init": "plugin-dev-init .",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@hookform/resolvers": "^5.2.2",
    "@repo/common": "workspace:*",
    "@repo/hooks": "workspace:*",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.563.0",
    "react-hook-form": "^7.71.1"
  },
  "devDependencies": {
    "@medusajs/admin-bundler": "2.13.5",
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/icons": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@medusajs/test-utils": "2.13.5",
    "@medusajs/ui": "4.0.25",
    "@repo/scripts": "workspace:*",
    "@repo/tsconfig": "workspace:*"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/icons": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@medusajs/test-utils": "2.13.5",
    "@medusajs/ui": "4.0.25"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.5.0"
}
