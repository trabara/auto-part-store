    "@medusajs/framework": "2.13.3",
    "@medusajs/icons": "2.13.3",
    "@medusajs/medusa": "2.13.3",
    "@medusajs/test-utils": "2.13.3",
    "@medusajs/ui": "4.0.25"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.5.0"
