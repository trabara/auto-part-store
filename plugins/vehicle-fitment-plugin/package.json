    "@medusajs/framework": "2.13.3",
    "@medusajs/icons": "2.13.3",
    "@medusajs/medusa": "patch:@medusajs/medusa@npm%3A2.13.3#~/.yarn/patches/@medusajs-medusa-npm-2.13.3-a5f2a940af.patch",
    "@medusajs/test-utils": "2.13.3",
    "@medusajs/ui": "4.0.25",
    "@repo/scripts": "workspace:*",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "chokidar": "^4.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
